# DeepSeek-V4 Monitor Configuration

# GitHub Token (Optional, to increase API rate limit)
GITHUB_TOKEN=

# Telegram Notification (Required for mobile alerts)
# 1. Message @BotFather on Telegram to get your Bot Token
# 2. Message @userinfobot to get your Chat ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional Settings
CHECK_INTERVAL=300
PRICE_ALERT_THRESHOLD=0.04
# TELEGRAM_PROXIES=http://127.0.0.1:7890
