# Copy to .env and fill in: cp .env.example .env

# GitHub API Token (optional — raises rate limit 60→5000/h)
MONITOR_GITHUB_TOKEN=

# DeepSeek API key (for LLM signal scoring)
DEEPSEEK_API_KEY=

# Max LLM calls per day (cost guard)
MAX_LLM_CALLS_PER_DAY=20

# Poll interval in seconds
CHECK_INTERVAL=300

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DB path (default: intelligence.db next to monitor.py)
# DB_PATH=intelligence.db
