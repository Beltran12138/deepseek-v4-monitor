# 复制此文件为 .env 并填入配置：cp .env.example .env

# GitHub API Token（可选，提升限额 60→5000次/h）
# 获取：https://github.com/settings/tokens
GITHUB_TOKEN=

# 检查间隔（秒）
CHECK_INTERVAL=300

# Polymarket 价格变动告警阈值
PRICE_ALERT_THRESHOLD=0.04

# ── 手机推送（填一个即可）────────────────────────

# ntfy（推荐，免费无需注册）
# 手机装 ntfy App 后订阅此 topic 即可收通知
# https://ntfy.sh/app
NTFY_TOPIC=deepseek-v4-your-unique-id

# Telegram（国内需代理）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PROXIES=
